# Postgres (lido pelo container do banco e pelo app via DATABASE_URL)
POSTGRES_DB=vicky
POSTGRES_USER=vicky
POSTGRES_PASSWORD=troque-isso-por-senha-forte

# Conexão da app -> banco (host = nome do service no compose)
DATABASE_URL=postgresql://vicky:troque-isso-por-senha-forte@vicky-db:5432/vicky

# OpenRouter (LLM)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_REFERER=https://vicky.synaptha.com
OPENROUTER_APP_TITLE=Vicky

# Rayyan (legado, pode deixar placeholders se nao usar)
RAYYAN_EMAIL=admin@example.com
RAYYAN_PASSWORD=anything
RAYYAN_REVIEW_ID=0
